RewriteEngine On

# Canonical host: force HTTPS and non-www.
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.musicdramaradio\.com$ [NC]
RewriteRule ^ https://musicdramaradio.com%{REQUEST_URI} [L,R=301]

# SPA fallback for client-side routes.
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
